rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      // Permite ler se for o criador ou se o e-mail estiver no sharedWith
      allow read: if request.auth != null && (
        resource.data.creator_id == request.auth.uid || 
        request.auth.token.email in resource.data.sharedWith
      );
      
      // Permite criar se estiver logado
      allow create: if request.auth != null;
      
      // Permite atualizar se for o criador ou estiver compartilhado (limitando campos se necessário, mas aqui liberado)
      allow update: if request.auth != null && (
        resource.data.creator_id == request.auth.uid || 
        request.auth.token.email in resource.data.sharedWith
      );
      
      // Apenas o criador pode deletar
      allow delete: if request.auth != null && resource.data.creator_id == request.auth.uid;
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
